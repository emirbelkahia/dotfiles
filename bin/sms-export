#!/usr/bin/env python3
"""sms-export — Export iPhone messages from a local Finder backup to HTML"""

# Auto-switch to the dedicated venv (set up by install.sh) so that
# iphone-backup-decrypt is available without any manual activation.
import os, sys
_VENV_DIR = os.path.expanduser("~/.venv/sms-export")
if os.path.exists(_VENV_DIR) and sys.prefix != _VENV_DIR:
    _VENV_PY = os.path.join(_VENV_DIR, "bin", "python3")
    os.execv(_VENV_PY, [_VENV_PY] + sys.argv)

import getpass
import hashlib
import plistlib
import re
import shutil
import sqlite3
import subprocess
import sys
import tempfile
import webbrowser
from datetime import datetime
from pathlib import Path

BACKUP_DIR  = Path.home() / "Library/Application Support/MobileSync/Backup"
SMS_HASH    = "3d0d7e5fb2ce288813306e4d4636395e047a3d28"
APPLE_EPOCH = 978307200  # seconds between Unix epoch and Apple epoch (2001-01-01)

# ── ANSI colors (same palette as tc / wt) ─────────────────────────────────────

B  = "\033[1m"
Y  = "\033[33m"
C  = "\033[36m"
G  = "\033[90m"
R  = "\033[0m"

# ── Helpers ───────────────────────────────────────────────────────────────────

def _bar(current: int, total: int, width: int = 28) -> str:
    filled = int(width * current / total) if total else width
    return "█" * filled + "░" * (width - filled)

def apple_ts(ts):
    if not ts:
        return None
    if ts > 1_000_000_000_000:  # nanoseconds (iOS 11+)
        ts /= 1_000_000_000
    try:
        return datetime.fromtimestamp(ts + APPLE_EPOCH)
    except Exception:
        return None

def h(s):
    if not s:
        return ""
    return (s.replace("&", "&amp;")
             .replace("<", "&lt;")
             .replace(">", "&gt;")
             .replace('"', "&quot;"))

def iphone_rel_path(filename: str) -> str | None:
    """Convert an attachment filename to an iPhone-relative path for iphone-backup-decrypt."""
    if filename.startswith("~/"):
        return filename[2:]                          # ~/Library/… → Library/…
    if filename.startswith("/var/mobile/"):
        return filename[len("/var/mobile/"):]        # /var/mobile/Library/… → Library/…
    return None

def attachment_backup_hash(filename: str) -> str | None:
    """Compute the SHA-1 backup hash for an attachment (unencrypted backups)."""
    if filename.startswith("~/"):
        rel    = filename[2:]           # ~/Library/… → Library/…
        domain = "HomeDomain"
    elif filename.startswith("/var/mobile/Media/"):
        rel    = filename[len("/var/mobile/Media/"):]
        domain = "MediaDomain"
    elif filename.startswith("/var/mobile/"):
        rel    = filename[len("/var/mobile/"):]
        domain = "HomeDomain"
    else:
        return None
    return hashlib.sha1(f"{domain}-{rel}".encode()).hexdigest()

# ── Contacts ─────────────────────────────────────────────────────────────────

def load_contacts(backup_dir: Path, enc_backup) -> dict:
    """Return {normalized_key -> display_name} from AddressBook.sqlitedb."""
    ab_hash = hashlib.sha1(b"HomeDomain-Library/AddressBook/AddressBook.sqlitedb").hexdigest()
    tmp = Path(tempfile.mktemp(suffix=".db"))
    try:
        if enc_backup is not None:
            try:
                enc_backup.extract_file(
                    relative_path="Library/AddressBook/AddressBook.sqlitedb",
                    output_filename=str(tmp),
                )
            except Exception:
                return {}
        else:
            src = backup_dir / ab_hash[:2] / ab_hash
            if not src.exists():
                return {}
            shutil.copy2(src, tmp)

        conn = sqlite3.connect(tmp)
        conn.row_factory = sqlite3.Row
        cur  = conn.cursor()

        cur.execute("SELECT ROWID, First, Last, Organization FROM ABPerson")
        persons = {}
        for row in cur.fetchall():
            name = f"{row['First'] or ''} {row['Last'] or ''}".strip() or (row["Organization"] or "")
            if name:
                persons[row["ROWID"]] = name

        # property 3 = phone, 4 = email
        cur.execute("""
            SELECT record_id, property, value
            FROM ABMultiValue
            WHERE property IN (3, 4) AND value IS NOT NULL
        """)
        contacts: dict = {}
        for row in cur.fetchall():
            pid = row["record_id"]
            if pid not in persons:
                continue
            val = (row["value"] or "").strip()
            if row["property"] == 3:  # phone — match on last 9 digits
                key = re.sub(r"\D", "", val)[-9:]
                if key:
                    contacts[key] = persons[pid]
            else:  # email
                contacts[val.lower()] = persons[pid]

        conn.close()
        return contacts

    except Exception:
        return {}
    finally:
        tmp.unlink(missing_ok=True)

def resolve_name(handle: str, contacts: dict) -> str:
    """Resolve a phone number or email to a contact display name."""
    if not handle:
        return handle
    if "@" in handle:
        return contacts.get(handle.lower(), handle)
    digits = re.sub(r"\D", "", handle)[-9:]
    return contacts.get(digits, handle)

# ── Attachment rendering ───────────────────────────────────────────────────────

def export_attachment(filename: str, mime_type: str,
                      backup_dir: Path, enc_backup,
                      atts_dir: Path, atts_name: str, used: set) -> str:
    """
    Copy/decrypt an attachment to atts_dir and return its HTML snippet.
    enc_backup is an EncryptedBackup instance or None for unencrypted backups.
    """
    mime      = (mime_type or "").lower()
    orig_name = Path(filename or "attachment").name

    # Plugin payloads (stickers, link previews, Apple Pay…) are binary blobs
    # with no displayable content — skip them silently.
    if orig_name.endswith(".pluginPayloadAttachment"):
        return ""

    # ── resolve output filename (handle duplicates) ───────────────────────────
    stem, ext = Path(orig_name).stem, Path(orig_name).suffix
    out_name  = orig_name
    n = 1
    while out_name in used:
        out_name = f"{stem}_{n}{ext}"
        n += 1
    used.add(out_name)
    dest = atts_dir / out_name
    rel  = f"{atts_name}/{out_name}"

    # ── copy/decrypt the file ─────────────────────────────────────────────────
    found = False
    if enc_backup is not None:
        rel_path = iphone_rel_path(filename)
        if rel_path:
            try:
                enc_backup.extract_file(relative_path=rel_path, output_filename=str(dest))
                found = dest.exists()
            except Exception:
                found = False
    else:
        file_hash = attachment_backup_hash(filename)
        if file_hash:
            src = backup_dir / file_hash[:2] / file_hash
            if src.exists():
                shutil.copy2(src, dest)
                found = True

    if not found:
        return f'<span class="att-badge">📎 {h(orig_name)} <em>(not found in backup)</em></span>'

    # ── render ────────────────────────────────────────────────────────────────
    if mime.startswith("image/"):
        return f'<img class="att-img" src="{rel}" alt="{h(orig_name)}">'
    if mime.startswith("video/"):
        return (f'<video class="att-video" controls src="{rel}">'
                f'<a href="{rel}">🎥 {h(orig_name)}</a></video>')
    if mime.startswith("audio/"):
        return f'<audio class="att-audio" controls src="{rel}"></audio>'
    return f'<a class="att-link" href="{rel}">📎 {h(orig_name)}</a>'

# ── Backup detection ──────────────────────────────────────────────────────────

def find_backup() -> tuple[Path, Path, datetime, bool]:
    """Return (sms_db_path, backup_dir, backup_date, is_encrypted)."""
    if not BACKUP_DIR.exists():
        die("No backup found. Plug your iPhone and create a backup via Finder.")

    try:
        backups = [d for d in BACKUP_DIR.iterdir() if d.is_dir() and (d / SMS_HASH[:2] / SMS_HASH).exists()]
    except PermissionError:
        die("Permission denied: ~/Library/Application Support/MobileSync/Backup\n"
            "  → System Settings → Privacy & Security → Full Disk Access\n"
            "  → Add your terminal (Terminal, iTerm2, Warp…) and relaunch it.")

    if not backups:
        die("No SMS database found.\n"
            "  → Plug your iPhone, open Finder, select your iPhone,\n"
            "    click 'Back Up Now'.")

    def backup_label(d: Path) -> str:
        info_path = d / "Info.plist"
        if info_path.exists():
            with open(info_path, "rb") as f:
                info = plistlib.load(f)
            device = info.get("Device Name") or info.get("Display Name") or d.name
            date   = info.get("Last Backup Date")
            date_s = date.strftime("%Y-%m-%d %H:%M") if date else "unknown date"
            return f"{device}  {G}({date_s}){R}"
        return d.name

    if len(backups) == 1:
        backup_dir = backups[0]
    else:
        print("Multiple backups found:")
        for i, b in enumerate(backups, 1):
            print(f"  {i}. {backup_label(b)}")
        choice = input("Which one? (number): ").strip()
        try:
            backup_dir = backups[int(choice) - 1]
        except (ValueError, IndexError):
            die("Invalid choice.")

    # Read backup date and encryption flag from Manifest.plist
    backup_date  = datetime.now()
    is_encrypted = False
    manifest     = backup_dir / "Manifest.plist"
    if manifest.exists():
        with open(manifest, "rb") as f:
            info = plistlib.load(f)
        backup_date  = info.get("Date", backup_date)
        is_encrypted = bool(info.get("IsEncrypted", False))
        if hasattr(backup_date, "replace"):
            backup_date = backup_date.replace(tzinfo=None)

    return backup_dir / SMS_HASH[:2] / SMS_HASH, backup_dir, backup_date, is_encrypted

# ── Encrypted backup setup ────────────────────────────────────────────────────

def open_encrypted_backup(backup_dir: Path):
    """Prompt for password and return an EncryptedBackup instance."""
    try:
        from iphone_backup_decrypt import EncryptedBackup
    except ImportError:
        die("Encrypted backup detected but iphone-backup-decrypt is not installed.\n"
            "  → Run install.sh to set up the required venv:\n"
            "    cd ~/dotfiles && ./install.sh")

    password = getpass.getpass("🔑 Backup password: ")
    try:
        enc = EncryptedBackup(backup_directory=str(backup_dir), passphrase=password)
        return enc
    except Exception as e:
        die(f"Failed to unlock backup (wrong password?)\n  {e}")

# ── Data loading ──────────────────────────────────────────────────────────────

def load_conversations(db_path: Path, enc_backup, contacts: dict | None = None) -> dict:
    """
    Load all conversations from the SMS database.
    enc_backup is an EncryptedBackup instance or None.
    contacts is the {normalized_key: display_name} dict from load_contacts().
    """
    tmp = Path(tempfile.mktemp(suffix=".db"))

    try:
        if enc_backup is not None:
            enc_backup.extract_file(
                relative_path="Library/SMS/sms.db",
                output_filename=str(tmp),
            )
        else:
            shutil.copy2(db_path, tmp)

        conn = sqlite3.connect(tmp)
        conn.row_factory = sqlite3.Row
        cur  = conn.cursor()

        try:
            cur.execute("SELECT count(*) FROM message")
        except sqlite3.DatabaseError:
            die("Database is encrypted.\n"
                "  → Redo the backup in Finder without checking 'Encrypt local backup',\n"
                "    or re-run sms-export with the correct password.")

        cur.execute("SELECT ROWID, id FROM handle")
        handles = {r["ROWID"]: r["id"] for r in cur.fetchall()}

        cur.execute("SELECT ROWID, chat_identifier, display_name FROM chat")
        chats = {r["ROWID"]: {"id": r["chat_identifier"], "name": r["display_name"]}
                 for r in cur.fetchall()}

        cur.execute("SELECT chat_id, message_id FROM chat_message_join")
        msg_to_chat = {r["message_id"]: r["chat_id"] for r in cur.fetchall()}

        attachments_by_msg: dict[int, list] = {}
        try:
            cur.execute("""
                SELECT maj.message_id, a.filename, a.mime_type
                FROM message_attachment_join maj
                JOIN attachment a ON a.ROWID = maj.attachment_id
            """)
            for row in cur.fetchall():
                attachments_by_msg.setdefault(row["message_id"], []).append({
                    "filename":  row["filename"] or "",
                    "mime_type": row["mime_type"] or "",
                })
        except sqlite3.OperationalError:
            pass

        cur.execute("""
            SELECT ROWID, text, date, is_from_me, handle_id, service
            FROM message ORDER BY date ASC
        """)

        rows = cur.fetchall()
        total_rows = len(rows)
        conversations: dict = {}
        for idx, row in enumerate(rows, 1):
            if idx % 200 == 0 or idx == total_rows:
                print(f"\r  [{_bar(idx, total_rows)}] {idx}/{total_rows} messages", end="", flush=True)

            text = (row["text"] or "").strip()
            atts = attachments_by_msg.get(row["ROWID"], [])
            if not text and not atts:
                continue

            chat_id = msg_to_chat.get(row["ROWID"])
            if chat_id and chat_id in chats:
                info = chats[chat_id]
                key  = info["id"]
                name = info["name"] or (resolve_name(key, contacts) if contacts else key)
            else:
                key  = handles.get(row["handle_id"], "Unknown")
                name = resolve_name(key, contacts) if contacts else key

            conversations.setdefault(key, {"name": name, "messages": []})
            conversations[key]["messages"].append({
                "text":    text,
                "date":    apple_ts(row["date"]),
                "from_me": bool(row["is_from_me"]),
                "atts":    atts,
            })
        if total_rows:
            print()  # clear the \r line

        conn.close()
        return conversations

    finally:
        tmp.unlink(missing_ok=True)

# ── HTML generation ───────────────────────────────────────────────────────────

def generate_html(conversations: dict, backup_dir: Path, enc_backup,
                  backup_date: datetime, atts_dir: Path, atts_name: str) -> str:

    sorted_convos = sorted(
        conversations.items(),
        key=lambda x: max(
            (m["date"] for m in x[1]["messages"] if m["date"]),
            default=datetime.min,
        ),
        reverse=True,
    )

    used_names: set = set()
    sidebar_items   = ""
    panels          = ""
    n_convos        = len(sorted_convos)

    for i, (key, convo) in enumerate(sorted_convos):
        print(f"\r  [{_bar(i + 1, n_convos)}] {i + 1}/{n_convos} conversations", end="", flush=True)
        name      = convo["name"] or key
        msgs      = convo["messages"]
        last      = next((m for m in reversed(msgs) if m["date"]), None)
        last_date = last["date"].strftime("%Y-%m-%d") if last else ""
        preview   = next((m["text"][:60] for m in reversed(msgs) if m["text"]), "📎 Attachment")
        sid       = f"c{i}"

        sidebar_items += f"""
        <div class="ci" onclick="show('{sid}')" id="i{sid}">
          <div class="cn">{h(name)}</div>
          <div class="cm">{last_date} · {len(msgs)} messages</div>
          <div class="cp">{h(preview)}</div>
        </div>"""

        bubbles = ""
        prev_dt = None
        for m in msgs:
            dt = m["date"]
            if dt and (prev_dt is None or (dt - prev_dt).total_seconds() > 3600):
                bubbles += f'<div class="ds">{dt.strftime("%A %B %d, %Y · %H:%M")}</div>'
                prev_dt = dt

            cls   = "me" if m["from_me"] else "th"
            t_str = dt.strftime("%H:%M") if dt else ""

            content = ""
            if m["text"]:
                content += f'<div class="bbl">{h(m["text"])}</div>'
            for att in m["atts"]:
                snippet = export_attachment(
                    att["filename"], att["mime_type"],
                    backup_dir, enc_backup,
                    atts_dir, atts_name, used_names,
                )
                content += f'<div class="bbl att">{snippet}</div>'

            bubbles += f"""
            <div class="msg {cls}">
              {content}
              <div class="mt">{t_str}</div>
            </div>"""

        panels += f"""
        <div class="panel" id="{sid}">
          <div class="ph">{h(name)}<span class="pc">{len(msgs)} messages</span></div>
          <div class="msgs">{bubbles}</div>
        </div>"""

    print()  # clear progress line

    total      = sum(len(c["messages"]) for c in conversations.values())
    export_dt  = datetime.now().strftime("%Y-%m-%d %H:%M")
    backup_str = backup_date.strftime("%Y-%m-%d %H:%M")

    all_dates  = [m["date"] for c in conversations.values() for m in c["messages"] if m["date"]]
    date_from  = min(all_dates).strftime("%b %-d, %Y") if all_dates else "unknown"
    date_to    = max(all_dates).strftime("%b %-d, %Y") if all_dates else "unknown"

    return f"""<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>iPhone Messages — {backup_date.strftime('%Y-%B-%d')}</title>
<style>
*{{box-sizing:border-box;margin:0;padding:0}}
body{{font-family:-apple-system,BlinkMacSystemFont,sans-serif;display:flex;height:100vh;background:#f5f5f5}}
#sb{{width:300px;background:#fff;border-right:1px solid #e0e0e0;overflow-y:auto;flex-shrink:0}}
#sbh{{padding:16px 16px 12px;border-bottom:1px solid #eee}}
#sbh h1{{font-size:17px;font-weight:700}}
#sbh .dr{{font-size:13px;font-weight:600;color:#007aff;margin-top:5px}}
#sbh .meta{{font-size:11px;color:#888;margin-top:3px}}
#sbh .gen{{font-size:10px;color:#bbb;margin-top:6px;padding-top:6px;border-top:1px solid #f0f0f0}}
#sbh .gen a{{color:#bbb;text-decoration:underline dotted;cursor:pointer}}
#search{{width:calc(100% - 32px);margin:10px 16px;padding:7px 10px;border:1px solid #ddd;border-radius:8px;font-size:13px;outline:none}}
.ci{{padding:11px 16px;border-bottom:1px solid #f0f0f0;cursor:pointer;transition:background .1s}}
.ci:hover{{background:#f8f8f8}}
.ci.active{{background:#007aff}}
.ci.active .cn,.ci.active .cm,.ci.active .cp{{color:#fff}}
.cn{{font-size:14px;font-weight:600;color:#111}}
.cm{{font-size:11px;color:#888;margin-top:2px}}
.cp{{font-size:12px;color:#aaa;margin-top:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}}
#main{{flex:1;display:flex;flex-direction:column;overflow:hidden}}
.panel{{display:none;flex-direction:column;height:100%}}
.panel.visible{{display:flex}}
.ph{{padding:14px 20px;background:#fff;border-bottom:1px solid #e0e0e0;font-size:15px;font-weight:600;display:flex;align-items:center;gap:10px}}
.pc{{font-size:12px;color:#888;font-weight:400}}
.msgs{{flex:1;overflow-y:auto;padding:16px 20px;display:flex;flex-direction:column;gap:3px}}
.ds{{text-align:center;font-size:11px;color:#888;margin:12px 0 4px;text-transform:capitalize}}
.msg{{display:flex;flex-direction:column;max-width:72%}}
.msg.me{{align-self:flex-end;align-items:flex-end}}
.msg.th{{align-self:flex-start;align-items:flex-start}}
.bbl{{padding:8px 13px;border-radius:18px;font-size:14px;line-height:1.45;white-space:pre-wrap;word-break:break-word}}
.me .bbl{{background:#007aff;color:#fff;border-bottom-right-radius:4px}}
.th .bbl{{background:#e5e5ea;color:#111;border-bottom-left-radius:4px}}
.bbl.att{{padding:4px;background:transparent!important}}
.att-img{{max-width:260px;max-height:320px;border-radius:14px;display:block}}
.att-video{{max-width:280px;border-radius:14px;display:block}}
.att-audio{{max-width:240px;margin:2px 0}}
.att-link{{display:inline-block;padding:6px 12px;border-radius:14px;font-size:13px;background:#e5e5ea;color:#333;text-decoration:none}}
.me .att-link{{background:#005ecb;color:#fff}}
.att-badge{{display:inline-block;padding:6px 12px;border-radius:14px;font-size:13px;background:#e5e5ea;color:#888}}
.bbl.match{{outline:2px solid #ffd60a;outline-offset:2px}}
.mt{{font-size:10px;color:#bbb;margin-top:2px;padding:0 4px}}
#empty{{display:flex;align-items:center;justify-content:center;height:100%;color:#ccc;font-size:15px}}
</style>
</head>
<body>
<div id="sb">
  <div id="sbh">
    <h1>iPhone Messages</h1>
    <div class="dr">📅 {date_from} → {date_to}</div>
    <div class="meta">{len(conversations)} conversations · {total} messages</div>
    <div class="gen">Generated by <a href="https://github.com/emirbelkahia/dotfiles" target="_blank" title="sms-export — custom CLI tool by Emir Belkahia&#10;Part of github.com/emirbelkahia/dotfiles&#10;Hover to see repo · click to open">sms-export</a> · backup {backup_str} · exported {export_dt}</div>
  </div>
  <input id="search" type="text" placeholder="Search conversations..." oninput="filter(this.value)">
  <div id="list">{sidebar_items}</div>
</div>
<div id="main">
  <div id="empty">← Select a conversation</div>
  {panels}
</div>
<script>
// Cache original sidebar previews so filter can restore them
document.querySelectorAll('.cp').forEach(e=>e.dataset.preview=e.textContent);
function show(id){{
  // Clear previous highlights and active state
  document.querySelectorAll('.panel').forEach(p=>{{
    p.classList.remove('visible');
    p.querySelectorAll('.bbl').forEach(b=>b.classList.remove('match'));
  }});
  document.querySelectorAll('.ci').forEach(i=>i.classList.remove('active'));
  const p=document.getElementById(id);
  const it=document.getElementById('i'+id);
  if(p){{
    p.classList.add('visible');
    const q=document.getElementById('search').value.toLowerCase();
    if(q){{
      // Highlight matching bubbles and scroll to first one
      let first=null;
      p.querySelectorAll('.bbl').forEach(b=>{{
        if(b.textContent.toLowerCase().includes(q)){{b.classList.add('match');if(!first)first=b;}}
      }});
      if(first)first.scrollIntoView({{block:'center',behavior:'smooth'}});
      else p.querySelector('.msgs').scrollTop=9e9;
    }}else p.querySelector('.msgs').scrollTop=9e9;
  }}
  if(it)it.classList.add('active');
  document.getElementById('empty').style.display='none';
}}
function filter(q){{
  q=q.toLowerCase();
  document.querySelectorAll('.ci').forEach(el=>{{
    const cp=el.querySelector('.cp');
    if(!q){{el.style.display='';cp.textContent=cp.dataset.preview;return;}}
    const nameMatch=el.querySelector('.cn').textContent.toLowerCase().includes(q);
    const panel=document.getElementById(el.id.replace('i',''));
    let msgMatch=false;
    if(panel){{
      for(const b of panel.querySelectorAll('.bbl')){{
        const t=b.textContent;
        if(t.toLowerCase().includes(q)){{
          msgMatch=true;
          // If match is in content (not name), update sidebar preview to show snippet
          if(!nameMatch){{
            const i=t.toLowerCase().indexOf(q),s=Math.max(0,i-25);
            cp.textContent=(s?'…':'')+t.slice(s,i+q.length+40)+(i+q.length+40<t.length?'…':'');
          }}
          break;
        }}
      }}
    }}
    if(nameMatch)cp.textContent=cp.dataset.preview;
    el.style.display=(nameMatch||msgMatch)?'':'none';
  }});
}}
</script>
</body>
</html>"""

# ── CLI ───────────────────────────────────────────────────────────────────────

def die(msg: str):
    print(f"❌ {msg}")
    sys.exit(1)

def show_help():
    print(f"""
{B}sms-export{R} — Export iPhone messages from a local Finder backup to HTML

{B}{Y}USAGE{R}
  {C}sms-export{R}          Auto-detect backup, generate HTML, open in browser
  {C}sms-export --help{R}   Show this help

{B}{Y}WHAT IT DOES{R}
  1. Finds your iPhone backup in {C}~/Library/Application Support/MobileSync/Backup/{R}
  2. If multiple backups exist, lists them by device name + date and asks which one to use
  3. Auto-detects whether the backup is encrypted or not
     {G}Encrypted   → prompts for your backup password, decrypts on the fly{R}
     {G}Unencrypted → reads directly, no password needed{R}
  4. Resolves phone numbers / emails to contact names from the AddressBook in the backup
  5. Exports all messages + attachments to disk, with a live progress counter
  6. Opens the HTML viewer in your browser — iMessage-style bubbles, searchable sidebar

{B}{Y}OUTPUT{R}
  {C}~/Documents/YYYY-Month-DD - Backup iMessage iPhone.html{R}  {G}← HTML viewer (date from backup){R}
  {C}~/Documents/YYYY-Month-DD - Backup iMessage iPhone/{R}      {G}← attachments folder{R}

  The HTML references attachments via relative paths — keep both in the same folder.

{B}{Y}ATTACHMENTS{R}
  {C}Photos{R}    Displayed inline via {C}<img>{R}
  {C}Video{R}     Playable inline via {C}<video>{R}
  {C}Audio{R}     Playable inline via {C}<audio>{R}
  {C}Other{R}     Clickable download link
  {G}If a file is missing from the backup, a "not found" badge is shown instead.{R}
  {G}Plugin payloads (stickers, link previews, Apple Pay) are silently skipped — unrenderable binary blobs.{R}

{B}{Y}CONTACTS{R}
  Names are resolved from the AddressBook stored inside the backup — no access to your live
  Contacts app needed. Phone numbers matched on the last 9 digits (handles +33 vs 06 etc.).
  Emails matched exactly (case-insensitive).
  {G}If a contact isn't found, the raw phone number or email is shown.{R}

{B}{Y}REQUIREMENTS{R}
  {C}Python 3{R}                   {G}standard library — always available on macOS{R}
  {C}Full Disk Access{R}           {G}required for your terminal app (to read the backup folder){R}
                             {G}System Settings → Privacy & Security → Full Disk Access{R}
                             {G}→ add Terminal / iTerm2 / Warp, then fully relaunch it{R}
  {C}iphone-backup-decrypt{R}      {G}only needed for encrypted backups{R}
                             {G}auto-installed by install.sh in an isolated venv: ~/.venv/sms-export/{R}
                             {G}source: github.com/jsharkey13/iphone_backup_decrypt{R}

{B}{Y}SETUP{R}  {G}(new machine — one time){R}
  {G}# 1. cd ~/dotfiles && ./install.sh{R}
  {G}#    → creates ~/.venv/sms-export/ and installs iphone-backup-decrypt{R}
  {G}# 2. Grant Full Disk Access to your terminal (see REQUIREMENTS above){R}
  {G}# 3. Plug iPhone → open Finder → select iPhone → Back Up Now{R}
  {G}#    Works with both encrypted and unencrypted backups.{R}
  {G}#    If encrypted: remember the backup password you set in Finder (≠ iPhone passcode).{R}

{B}{Y}COMPATIBILITY{R}
  Tested on iOS 17 / macOS 15. The sms.db schema has been stable since iOS 11.
  The backup file layout (hash = SHA-1 of domain+relativePath) is unchanged since iOS 5.
  If a future iOS update breaks something:
    → check for iphone-backup-decrypt updates:
      {C}~/.venv/sms-export/bin/pip install -U iphone-backup-decrypt{R}
    → report schema changes at github.com/jsharkey13/iphone_backup_decrypt

{B}{Y}TROUBLESHOOTING{R}
  {C}Permission denied{R}        Grant Full Disk Access to your terminal and relaunch it
  {C}No backup found{R}          Plug iPhone → Finder → Back Up Now
  {C}Wrong password{R}           Backup password is set in Finder, not your iPhone passcode
  {C}iphone-backup-decrypt{R}    Re-run install.sh, or activate venv manually:
    {G}source ~/.venv/sms-export/bin/activate && pip install -U iphone-backup-decrypt{R}
  {C}WARN: decrypted…{R}         Harmless size mismatch warning from the decrypt lib — output is correct
  {C}Missing images{R}           File wasn't included in the backup (can happen with some media types)
""")

def main():
    if "--help" in sys.argv or "-h" in sys.argv:
        show_help()
        sys.exit(0)

    print("🔍 Looking for iPhone backup...")
    db_path, backup_dir, backup_date, is_encrypted = find_backup()

    enc_backup = None
    if is_encrypted:
        print("🔒 Encrypted backup detected — password required.")
        enc_backup = open_encrypted_backup(backup_dir)
        print("✅ Backup unlocked.")
    else:
        print("🔓 Unencrypted backup — no password needed.")

    print(f"📅 Backup from {backup_date.strftime('%Y-%m-%d %H:%M')}")
    print("👤 Loading contacts...")
    contacts = load_contacts(backup_dir, enc_backup)
    if contacts:
        print(f"   {len(contacts)} contact entries loaded.")
    else:
        print("   No contacts found — phone numbers will be shown as-is.")
    print("📖 Reading messages...")
    conversations = load_conversations(db_path, enc_backup, contacts)

    total = sum(len(c["messages"]) for c in conversations.values())
    print(f"✅ {len(conversations)} conversations · {total} messages")
    print("📎 Exporting attachments and generating HTML...")

    month_name = backup_date.strftime("%B")
    base_name  = f"{backup_date.strftime('%Y')}-{month_name}-{backup_date.strftime('%d')} - Backup iMessage iPhone"
    docs       = Path.home() / "Documents"
    atts_dir   = docs / base_name
    atts_dir.mkdir(parents=True, exist_ok=True)

    html   = generate_html(conversations, backup_dir, enc_backup,
                           backup_date, atts_dir, base_name)
    output = docs / f"{base_name}.html"
    output.write_text(html, encoding="utf-8")

    att_count = sum(1 for _ in atts_dir.iterdir())
    print(f"✅ Exported: {output}")
    print(f"📁 Attachments: {atts_dir}  ({att_count} files)")
    webbrowser.open(f"file://{output}")
    subprocess.run(["afplay", "/System/Library/Sounds/Funk.aiff"], check=False)

if __name__ == "__main__":
    main()
