#!/bin/bash
# tc — Transcribe a call recording and generate a CSM summary prompt

set -euo pipefail

# === CONFIG ===
MOVIES_DIR="$HOME/Movies"
NOTES_DIR="$HOME/Notes/Calls"
WHISPER_DIR="$HOME/whisper.cpp"
WHISPER_BIN="$WHISPER_DIR/build/bin/whisper-cli"
WHISPER_MODEL="$WHISPER_DIR/models/ggml-large-v3-turbo.bin"
VAD_MODEL="$WHISPER_DIR/models/for-tests-silero-v5.1.2-ggml.bin"
SAMPLE_RATE=16000

# VAD defaults
VAD_ENABLED=true
VAD_THRESHOLD=0.5

# ── Help ──────────────────────────────────────────────────────────────────────

show_help() {
  local b='\033[1m'
  local y='\033[33m'
  local c='\033[36m'
  local g='\033[90m'
  local r='\033[0m'

  printf "${b}tc${r} — Transcribe a call recording and generate a CSM summary prompt\n"
  printf "\n"
  printf "${b}${y}USAGE${r}\n"
  printf "  ${c}tc${r}          Interactive — auto-detects the most recent recording (up to 15 days back)\n"
  printf "  ${c}tc --help${r}   Show this help\n"
  printf "\n"
  printf "${b}${y}WHAT IT DOES${r}\n"
  printf "  1. Auto-detects the most recent call recording in ${c}~/Movies${r} (up to 15 days back)\n"
  printf "  2. Converts audio to WAV 16kHz mono via ffmpeg\n"
  printf "  3. Transcribes with Whisper large-v3-turbo + optional VAD\n"
  printf "  4. Optionally diarizes the transcript (speaker labels) via pyannote\n"
  printf "  5. Generates a CSM internal Slack-ready Markdown prompt\n"
  printf "  6. Opens the prompt in TextEdit — paste into Claude or ChatGPT\n"
  printf "\n"
  printf "${b}${y}OUTPUT${r}\n"
  printf "  ${c}~/Movies/YYYY-MM-DD_call-name.txt${r}              ${g}← transcript${r}\n"
  printf "  ${c}~/Movies/YYYY-MM-DD_call-name-diarized.txt${r}     ${g}← transcript with speaker labels (optional)${r}\n"
  printf "  ${c}~/Notes/Calls/YYYY-MM-DD_call-name_prompt.txt${r}  ${g}← generated prompt${r}\n"
  printf "\n"
  printf "${b}${y}DEPENDENCIES${r}\n"
  printf "  ${c}ffmpeg${r}       ${g}brew install ffmpeg  (handled by install.sh)${r}\n"
  printf "  ${c}whisper.cpp${r}  ${g}see SETUP below${r}\n"
  printf "  ${c}HF_TOKEN${r}     ${g}optional — required for speaker diarization (see install.sh)${r}\n"
  printf "\n"
  printf "${b}${y}SETUP${r}  ${g}(new machine — one time)${r}\n"
  printf "  ${g}# 1. Clone and build whisper.cpp${r}\n"
  printf "  ${c}git clone https://github.com/ggerganov/whisper.cpp.git ~/whisper.cpp${r}\n"
  printf "  ${c}cmake -B ~/whisper.cpp/build ~/whisper.cpp${r}\n"
  printf "  ${c}cmake --build ~/whisper.cpp/build --config Release${r}\n"
  printf "\n"
  printf "  ${g}# 2. Download models into ~/whisper.cpp/models/${r}\n"
  printf "  ${c}cd ~/whisper.cpp && bash models/download-ggml-model.sh large-v3-turbo${r}\n"
  printf "  ${g}# VAD model: download for-tests-silero-v5.1.2-ggml.bin from whisper.cpp releases${r}\n"
  printf "\n"
  printf "  ${g}# 3. Recordings must be named YYYY-MM-DD*.mov or *.mp4 and placed in ~/Movies${r}\n"
}

case "${1:-}" in
  --help|-h) show_help; exit 0 ;;
esac

# ── Main ──────────────────────────────────────────────────────────────────────

mkdir -p "$NOTES_DIR"

# === LOGGING ===
TODAY=$(date "+%Y-%m-%d")
# Cleanup on abnormal exit
cleanup() {
  if [[ -n "${WAV_PATH:-}" && -f "$WAV_PATH" ]]; then rm -f "$WAV_PATH"; fi
  if [[ -n "${VTT_PATH:-}" && -f "$VTT_PATH" ]]; then rm -f "$VTT_PATH"; fi
}
trap cleanup EXIT

echo "═══════════════════════════════════════════════════════════════"
echo "  🎙️  Transcript Call — Whisper + VAD + Diarization"
echo "═══════════════════════════════════════════════════════════════"
echo ""

# === FIND VIDEO FILE ===
# Look for recordings from today first, then fall back up to 15 days back
CALLS_FOUND=()
SEARCH_DATE="$TODAY"

for i in $(seq 0 14); do
  CANDIDATE_DATE=$(date -v-${i}d "+%Y-%m-%d" 2>/dev/null || date -d "-${i} days" "+%Y-%m-%d")
  IFS=$'\n' read -r -d '' -a CANDIDATE_FILES < <(find "$MOVIES_DIR" -type f \( -name "${CANDIDATE_DATE}*.mov" -o -name "${CANDIDATE_DATE}*.mp4" \) | sort && printf '\0')
  if [ ${#CANDIDATE_FILES[@]} -gt 0 ]; then
    CALLS_FOUND=("${CANDIDATE_FILES[@]}")
    SEARCH_DATE="$CANDIDATE_DATE"
    if [ "$i" -gt 0 ]; then
      echo "🔍 No file found today ($TODAY) — nearest recording found: $SEARCH_DATE"
    fi
    break
  fi
done

if [ ${#CALLS_FOUND[@]} -eq 0 ]; then
  echo "❌ No .mov or .mp4 file found in the last 15 days."
  afplay /System/Library/Sounds/Basso.aiff || true
  exit 1
elif [ ${#CALLS_FOUND[@]} -eq 1 ]; then
  SELECTED_FILE="${CALLS_FOUND[0]}"
  echo "📹 File detected: $SELECTED_FILE"
else
  echo "📋 Multiple files found on $SEARCH_DATE. Which one?"
  select OPTION in "${CALLS_FOUND[@]}"; do
    if [[ -n "${OPTION:-}" ]]; then
      SELECTED_FILE="$OPTION"
      break
    else
      echo "❌ Invalid choice, try again"
    fi
  done
fi

# === CALL NAME ===
echo ""
read -r -p "📝 Call name (e.g. demo-client-x) : " CALL_NAME
CALL_NAME_CLEAN=$(echo "$CALL_NAME" | tr ' ' '-' | tr -cd '[:alnum:]-_')
BASENAME="${SEARCH_DATE}_${CALL_NAME_CLEAN}"
WAV_PATH="$MOVIES_DIR/${BASENAME}.wav"
TXT_PATH="$MOVIES_DIR/${BASENAME}.txt"
VTT_PATH="$MOVIES_DIR/${BASENAME}.vtt"
RAW_TRANSCRIPT="${WAV_PATH}.txt"
RAW_VTT="${WAV_PATH}.vtt"
PROMPT_PATH="$NOTES_DIR/${BASENAME}_prompt.txt"

# === LANGUAGE ===
DEFAULT_LANG="fr"
read -r -p "🌍 Call language (2-letter code, e.g. fr/en) [${DEFAULT_LANG}] or 'auto' : " LANGUAGE
LANGUAGE=${LANGUAGE:-$DEFAULT_LANG}
LANGUAGE=$(echo "$LANGUAGE" | tr '[:upper:]' '[:lower:]')

if ! [[ "$LANGUAGE" =~ ^[a-z]{2}$ || "$LANGUAGE" == "auto" ]]; then
  echo "⚠️  Invalid language code. Using default '${DEFAULT_LANG}'."
  LANGUAGE="$DEFAULT_LANG"
fi

# === VAD CONFIGURATION ===
echo ""
echo "🎯 Voice Activity Detection (VAD) — filters silence to prevent hallucinations"
read -r -p "   Enable VAD? (Y/n) [Y] : " VAD_CHOICE
VAD_CHOICE=$(echo "${VAD_CHOICE:-y}" | tr '[:upper:]' '[:lower:]')

if [[ "$VAD_CHOICE" =~ ^(n|no)$ ]]; then
  VAD_ENABLED=false
  echo "   ⚠️  VAD disabled — hallucinations on silent parts are possible"
else
  VAD_ENABLED=true
  echo "   ✅ VAD enabled"

  if [ ! -f "$VAD_MODEL" ]; then
    echo "   ❌ VAD model not found: $VAD_MODEL"
    echo "   Download it or disable VAD."
    VAD_ENABLED=false
  else
    read -r -p "   VAD threshold (0.3=sensitive, 0.5=normal, 0.7=strict) [0.5] : " VAD_THRESHOLD_INPUT
    if [[ -n "$VAD_THRESHOLD_INPUT" && "$VAD_THRESHOLD_INPUT" =~ ^0\.[0-9]+$ ]]; then
      VAD_THRESHOLD="$VAD_THRESHOLD_INPUT"
    fi
    echo "   Threshold: $VAD_THRESHOLD"
  fi
fi

# === DIARIZATION CONFIGURATION ===
DIARIZE_ENABLED=false
DIARIZE_VENV="$HOME/.venv/tc-diarize"
DIARIZE_SCRIPT="$HOME/dotfiles/lib/tcd.py"

echo ""
echo "🎙️  Speaker diarization — labels each segment with SPEAKER_00, SPEAKER_01..."

if [[ -z "${HF_TOKEN:-}" ]]; then
  echo "   ⚠️  Unavailable — HF_TOKEN not set in ~/.zshrc (see install.sh)"
elif [[ ! -f "$DIARIZE_VENV/bin/python3" ]]; then
  echo "   ⚠️  Unavailable — venv missing, re-run install.sh"
elif [[ ! -f "$DIARIZE_SCRIPT" ]]; then
  echo "   ⚠️  Unavailable — tcd.py missing from ~/dotfiles/lib/"
else
  read -r -p "   Enable? (Y/n) [Y] : " DIARIZE_CHOICE
  DIARIZE_CHOICE=$(echo "${DIARIZE_CHOICE:-y}" | tr '[:upper:]' '[:lower:]')
  if [[ ! "$DIARIZE_CHOICE" =~ ^(n|no)$ ]]; then
    DIARIZE_ENABLED=true
    echo "   ✅ Diarization enabled"
  else
    echo "   ⏭️  Diarization disabled"
  fi
fi

# === CHECK EXISTING TRANSCRIPTS ===
IFS=$'\n' read -r -d '' -a TXT_CANDIDATES < <(find "$MOVIES_DIR" -type f -name "${SEARCH_DATE}*.txt" | sort && printf '\0')
USE_EXISTING=""

if [ ${#TXT_CANDIDATES[@]} -gt 0 ]; then
  echo ""
  echo "📄 Existing transcripts found for $SEARCH_DATE. Use one?"
  select EXISTING_TXT in "${TXT_CANDIDATES[@]}" "Create a new transcript"; do
    if [[ "$REPLY" == "$((${#TXT_CANDIDATES[@]}+1))" ]] || [[ -z "${REPLY:-}" ]]; then
      echo "👉 Creating a new transcript."
      break
    elif [[ -n "${EXISTING_TXT:-}" ]]; then
      USE_EXISTING="$EXISTING_TXT"
      echo "✅ Using: $USE_EXISTING"
      if [[ "$(realpath "$USE_EXISTING")" != "$(realpath "$TXT_PATH" 2>/dev/null || echo "$TXT_PATH")" ]]; then
        cp "$USE_EXISTING" "$TXT_PATH"
      else
        echo "ℹ️  File already in place, no copy needed."
      fi
      TXT_PATH="$USE_EXISTING"
      break
    else
      echo "❌ Invalid choice, try again"
    fi
  done
fi

# === TRANSCRIBE ===
if [ ! -f "$TXT_PATH" ]; then
  echo ""
  echo "🎧 Converting to WAV (16kHz mono)..."
  ffmpeg -y -i "$SELECTED_FILE" -ar $SAMPLE_RATE -ac 1 -c:a pcm_s16le "$WAV_PATH" 2>/dev/null

  DURATION=$(ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$WAV_PATH" 2>/dev/null | cut -d. -f1)
  DURATION_MIN=$((DURATION / 60))
  DURATION_SEC=$((DURATION % 60))
  echo "   Duration: ${DURATION_MIN}m ${DURATION_SEC}s"

  echo ""
  echo "🧠 Transcribing with Whisper..."

  WHISPER_ARGS=(-m "$WHISPER_MODEL" -f "$WAV_PATH" -otxt)
  if [[ "$DIARIZE_ENABLED" == true ]]; then
    WHISPER_ARGS+=(-ovtt)
  fi

  if [[ "$LANGUAGE" != "auto" ]]; then
    WHISPER_ARGS+=(--language "$LANGUAGE")
  fi

  if [[ "$VAD_ENABLED" == true ]]; then
    echo "   🎯 VAD enabled (threshold: $VAD_THRESHOLD)"
    WHISPER_ARGS+=(--vad)
    WHISPER_ARGS+=(--vad-model "$VAD_MODEL")
    WHISPER_ARGS+=(--vad-threshold "$VAD_THRESHOLD")
  fi

  "$WHISPER_BIN" "${WHISPER_ARGS[@]}"

  if [ -f "$RAW_TRANSCRIPT" ]; then
    mv "$RAW_TRANSCRIPT" "$TXT_PATH"
    if [[ "$DIARIZE_ENABLED" == true && -f "$RAW_VTT" ]]; then
      mv "$RAW_VTT" "$VTT_PATH"
    fi
    if [[ "$DIARIZE_ENABLED" != true ]]; then
      rm -f "$WAV_PATH"
    fi
    LINE_COUNT=$(wc -l < "$TXT_PATH" | tr -d ' ')
    echo ""
    echo "✅ Transcription done: $LINE_COUNT lines"
  else
    echo "❌ Error: transcript missing."
    afplay /System/Library/Sounds/Basso.aiff || true
    exit 1
  fi
fi

# === DIARIZATION ===
if [[ "$DIARIZE_ENABLED" == true ]]; then
  # If we used an existing transcript, WAV/VTT may not exist — re-create them
  if [[ ! -f "$WAV_PATH" ]]; then
    echo ""
    echo "🎧 Re-converting to WAV for diarization..."
    ffmpeg -y -i "$SELECTED_FILE" -ar $SAMPLE_RATE -ac 1 -c:a pcm_s16le "$WAV_PATH" 2>/dev/null
  fi
  if [[ ! -f "$VTT_PATH" ]]; then
    echo "   Generating timestamps (VTT) for alignment..."
    "$WHISPER_BIN" -m "$WHISPER_MODEL" -f "$WAV_PATH" -ovtt --language "$LANGUAGE" 2>/dev/null
    [[ -f "$RAW_VTT" ]] && mv "$RAW_VTT" "$VTT_PATH"
  fi

  DIARIZED_TXT="${TXT_PATH%.txt}-diarized.txt"
  echo ""
  echo "🎙️  Running diarization (may take 1-2 min)..."

  if "$DIARIZE_VENV/bin/python3" "$DIARIZE_SCRIPT" "$WAV_PATH" "$VTT_PATH" > "$DIARIZED_TXT" 2>/tmp/tcd-error.log; then
    TXT_PATH="$DIARIZED_TXT"
    LINE_COUNT=$(wc -l < "$TXT_PATH" | tr -d ' ')
    echo "   ✅ Diarization done: $LINE_COUNT segments → $DIARIZED_TXT"
  else
    echo "   ⚠️  Diarization failed — falling back to plain transcript"
    echo "   $(tail -1 /tmp/tcd-error.log)"
    rm -f "$DIARIZED_TXT"
  fi

  rm -f "$WAV_PATH" "$VTT_PATH"
fi

# === CONTEXT + PROMPT ===
echo ""
read -r -p "🧾 Call context (client, stakes, objective) : " CONTEXT

TRANSCRIPT=$(cat "$TXT_PATH")

PROMPT=$(cat <<EOF
You are a world-class Customer Success Manager (CSM), working at Algolia.

You are Emir Belkahia, and you're writing an internal update for your colleagues (not for the client). Your tone must reflect ownership, strategic thinking, and clear next steps. This message is meant to be shared in Slack internally, to help the team understand what's important about this customer interaction, how it impacts the account, and what actions are needed.

---

Always respond in professional, structured English, and format the response in Markdown ready to be pasted in Slack.

Start your summary with a **clear title** that includes the name of the client and the topic of the call, like:
"# 📞 Statut merch – Raja France – ${SEARCH_DATE}"

Here is the context of the call:
$CONTEXT

Here is the full call transcript (language code: ${LANGUAGE}):
$TRANSCRIPT

---

Structure your response like this:

# 🧠 TL;DR
(1-2 sentence high-level summary)

# 📌 Key Points
- Bullet points summarizing strategic takeaways, blockers, goals, risks, decisions, etc.

# ✅ Next Steps
- [ ] Action item 1 (clearly phrased, ideally with assignee or implicit owner)
- [ ] Action item 2
EOF
)

echo "$PROMPT" > "$PROMPT_PATH"
echo ""
echo "═══════════════════════════════════════════════════════════════"
echo "✅ Done!"
echo ""
echo "📄 Transcript : $TXT_PATH"
echo "📝 Prompt     : $PROMPT_PATH"
echo "═══════════════════════════════════════════════════════════════"

open -a TextEdit "$PROMPT_PATH"
afplay /System/Library/Sounds/Funk.aiff || true
